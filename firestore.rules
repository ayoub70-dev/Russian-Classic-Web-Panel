rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Authors directory paths
    match /authors/{authorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Classical books catalog nodes
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Nested Chapters subcollections
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        // Nested Pages text contents
        match /pages/{pageId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }
  }
}
